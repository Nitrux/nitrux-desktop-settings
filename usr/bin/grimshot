#!/usr/bin/env bash

# SPDX-License-Identifier: BSD-3-Clause
# Copyright 2025 <Nitrux Latinoamericana S.C. <hello@nxos.org>>


# -- Exit on errors.

set -eu


# -- The script has two flags: -f for full-screen and -s for region selection (via slurp). It saves to ~/Pictures/, copies to the clipboard, and shows a styled notification.

mode=""
while getopts "fsw" opt; do
    case "$opt" in
        f) mode="full";;
        s) mode="select";;
        w) mode="window";;
        *) echo "Usage: $0 [-f | -s | -w]"; exit 2;;
    esac
done

if [ -z "${mode}" ]; then
    echo "Usage: $0 [-f | -s | -w]"
    exit 2
fi

xdg_dirs="${XDG_CONFIG_HOME:-$HOME/.config}/user-dirs.dirs"
if [ -r "$xdg_dirs" ]; then
    # shellcheck source=/dev/null
    . "$xdg_dirs"
fi

outdir="${XDG_PICTURES_DIR:-$HOME/Pictures}"
mkdir -p "$outdir"
outfile="$outdir/screenshot-$(date +'%Y%m%d-%H%M%S').png"
tmpfile=""

cleanup() {
    if [ -n "${tmpfile}" ] && [ -f "${tmpfile}" ]; then
        rm -f "${tmpfile}"
    fi
}
trap cleanup EXIT

notify_success() {
    wl-copy -t image/png < "$outfile"
    notify-send -a "Grimshot" -u normal -i "$outfile" "Screenshot Taken" "Saved to: $outfile\n\nAlso copied to clipboard."
}

validate_capture() {
    local img="$1"
    local dims
    local width
    local height

    [ -s "$img" ] || return 1

    dims="$(file "$img" 2>/dev/null | sed -n 's/.*PNG image data, \([0-9][0-9]*\) x \([0-9][0-9]*\).*/\1 \2/p' || true)"

    if [ -z "$dims" ]; then
        return 0
    fi

    width="${dims% *}"
    height="${dims#* }"

    [ "$width" -gt 2 ] && [ "$height" -gt 2 ]
}

capture_with_retries() {
    local attempts=4
    local attempt=1
    local delay="0.12"

    tmpfile="$(mktemp "${outdir}/.grimshot-XXXXXX.png")"

    while [ "$attempt" -le "$attempts" ]; do
        # Let selection overlays/animations settle before reading the frame.
        sleep "$delay"
        if grim "$@" "$tmpfile" && validate_capture "$tmpfile"; then
            mv "$tmpfile" "$outfile"
            tmpfile=""
            return 0
        fi

        attempt=$((attempt + 1))
        sleep "$delay"
    done

    return 1
}

if [ "$mode" = "full" ]; then
    if capture_with_retries; then
        notify_success
    else
        notify-send -a "Grimshot" -u critical -i "dialog-error" "Screenshot Failed" "Could not capture full-screen image."
        exit 1
    fi
else
    if [ "$mode" = "window" ]; then
        active_workspace="$(hyprctl activeworkspace -j | jq '.id')"
        geom="$(hyprctl clients -j | jq -r ".[] | select(.workspace.id == ${active_workspace} and .size[0] > 2 and .size[1] > 2) | \"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])\"" | slurp || true)"
    else
        geom="$(slurp || true)"
    fi

    if [ -z "${geom}" ]; then
        notify-send -a "Grimshot" -u low -i "dialog-information" "Screenshot Cancelled" "No selection made."
        exit 1
    fi

    if capture_with_retries -g "$geom"; then
        notify_success
    else
        notify-send -a "Grimshot" -u critical -i "dialog-error" "Screenshot Failed" "Could not capture selected area."
        exit 1
    fi
fi
