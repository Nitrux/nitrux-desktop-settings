#!/usr/bin/env bash

# SPDX-License-Identifier: BSD-3-Clause
# Copyright 2024-2026 <Nitrux Latinoamericana S.C. <hello@nxos.org>>

set -u

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2
}

current_user="${USER:-$(id -un)}"
current_uid="$(id -u)"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${current_uid}}"


# -- 1. CRITICAL: Pre-flight check.

check_binary() {
    if ! command -v "$1" >/dev/null 2>&1; then
        log "FATAL: Executable '$1' not found in \$PATH."
        log "Current PATH: $PATH"
        exit 1
    fi
}

check_binary pipewire
check_binary pipewire-pulse
check_binary wireplumber


# -- 2. Environment checks.

if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
    if [ -e "${runtime_dir}/bus" ]; then
        DBUS_SESSION_BUS_ADDRESS="unix:path=${runtime_dir}/bus"
        export DBUS_SESSION_BUS_ADDRESS
        log "inferred DBUS_SESSION_BUS_ADDRESS"
    else
        log "WARNING: DBUS_SESSION_BUS_ADDRESS is unset. PipeWire may fail."
    fi
fi

is_running() {
    pgrep -u "${current_user}" -x "$1" >/dev/null 2>&1
}

is_audio_stack_ready() {
    if ! timeout 2s pactl info >/dev/null 2>&1; then
        return 1
    fi

    if command -v wpctl >/dev/null 2>&1; then
        timeout 2s wpctl status >/dev/null 2>&1
        return $?
    fi

    return 0
}

cleanup_audio_stack() {
    log "Cleaning up stale PipeWire/WirePlumber processes..."
    pkill -u "${current_user}" -x wireplumber >/dev/null 2>&1 || true
    sleep 1
    pkill -u "${current_user}" -x pipewire-pulse >/dev/null 2>&1 || true
    sleep 1
    pkill -u "${current_user}" -x pipewire >/dev/null 2>&1 || true
    sleep 1

    if ! is_running pipewire; then
        rm -f "${runtime_dir}/pipewire-0" "${runtime_dir}/pipewire-0.lock" >/dev/null 2>&1 || true
    fi

    if ! is_running pipewire-pulse; then
        rm -f "${runtime_dir}/pulse/native" "${runtime_dir}/pulse/pid" >/dev/null 2>&1 || true
    fi
}


# -- 3. Robust process starter.

start_process() {
    local process="$1"
    shift 

    local max_retries=3
    local attempt=1

    if is_running "$process"; then
        log "$process is already running."
        return 0
    fi

    log "Starting $process..."

    while (( attempt <= max_retries )); do
        nohup "$process" "$@" >/dev/null 2>&1 &
        local pid=$!
        
        sleep 1

        if kill -0 "$pid" >/dev/null 2>&1; then
            log "$process started successfully (PID: $pid)"
            return 0
        else
            log "WARNING: $process failed to start (Attempt $attempt/$max_retries). Cleaning up..."
            pkill -u "${current_user}" -x "$process" >/dev/null 2>&1 || true
            sleep 1
        fi
        
        attempt=$((attempt + 1))
    done

    log "ERROR: Could not start $process after $max_retries attempts."
    return 1
}


# -- 4. Execution.

if is_audio_stack_ready; then
    log "PipeWire audio stack is already operational."
else
    log "PipeWire stack is not healthy. Attempting recovery..."

    stack_ok=false
    for attempt in 1 2 3; do
        log "Recovery attempt $attempt/3..."
        cleanup_audio_stack

        start_process pipewire || true
        start_process pipewire-pulse || true
        sleep 1
        start_process wireplumber || true

        log "Waiting for PipeWire to be ready..."
        if is_audio_stack_ready; then
            log "PipeWire recovered successfully."
            stack_ok=true
            break
        fi
    done

    if [ "$stack_ok" = false ]; then
        log "ERROR: Audio stack is still not operational after recovery attempts."
    fi
fi


# -- 5. Verification.

if is_audio_stack_ready; then
    log "PipeWire is fully operational."
else
    log "WARNING: PipeWire verification failed."
fi


# -- 6. Audio Test.

audio_sample="/usr/share/sounds/freedesktop/stereo/service-login.oga"

if [ -f "$audio_sample" ]; then
    log "Playing test sound..."
    
    if command -v pw-play >/dev/null 2>&1; then
        timeout 2s pw-play "$audio_sample" >/dev/null 2>&1 && log "Audio test passed (pw-play)."
    elif command -v paplay >/dev/null 2>&1; then
        timeout 2s paplay "$audio_sample" >/dev/null 2>&1 && log "Audio test passed (paplay)."
    else
        log "WARNING: No suitable player (pw-play/paplay) found for .oga files."
    fi
fi
